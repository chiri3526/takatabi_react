---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getArticleById, getArticles } from '../../lib/microcms';
import { CATEGORIES, articleId, articlePath, categoryKeyForArticle, categoryPath, excerptFromArticle, formatDate, imageUrl, stripHtml, tagLabels, withToc } from '../../lib/site';

export async function getStaticPaths() {
  const articles = await getArticles();
  return articles.map(article => ({
    params: { id: articleId(article) },
    props: { article }
  }));
}

const id = Astro.params.id || '';
const article = Astro.props.article || await getArticleById(id);

if (!article) {
  return Astro.redirect('/404/');
}

const allArticles = await getArticles();
const categoryKey = categoryKeyForArticle(article);
const related = allArticles
  .filter(item => categoryKeyForArticle(item) === categoryKey && articleId(item) !== articleId(article))
  .slice(0, 3);
const popular = allArticles.filter(item => articleId(item) !== articleId(article)).slice(0, 4);
const { toc, html } = withToc(article.content || '');
const tags = tagLabels(article);
const publishedAt = article.publishedAt || article.createdAt || article.updatedAt;
const published = formatDate(publishedAt);
const publishedCompactDate = publishedAt ? new Date(publishedAt) : null;
const publishedCompact = publishedCompactDate && !Number.isNaN(publishedCompactDate.getTime())
  ? [
    publishedCompactDate.getFullYear(),
    String(publishedCompactDate.getMonth() + 1).padStart(2, '0'),
    String(publishedCompactDate.getDate()).padStart(2, '0')
  ].join('/')
  : published;
const readingMinutes = Math.max(1, Math.ceil(stripHtml(article.content || '').length / 500));
const canonical = articlePath(article);
---
<BaseLayout
  title={article.title || 'Article'}
  description={excerptFromArticle(article)}
  canonical={canonical}
  image={imageUrl(article.image)}
>
  <header class="site-nav">
    <a class="brand" href="/">takatabi</a>
    <nav class="nav-links" aria-label="Main navigation">
      {CATEGORIES.map(category => <a href={categoryPath(category.key)} aria-current={category.key === categoryKey ? 'page' : undefined}>{category.label}</a>)}
    </nav>
    <button class="subscribe" type="button">Subscribe</button>
  </header>

  <main class="article-wrap">
    <section class="article-hero">
      <img src={imageUrl(article.image)} alt={article.title || ''} />
      <div class="article-hero__text">
        <h1>{article.title}</h1>
        <div class="article-hero__meta" aria-label="Article metadata">
          <span class="article-hero__pill">{readingMinutes} min read</span>
          {publishedCompact && <span class="article-hero__pill">{publishedCompact}</span>}
        </div>
      </div>
    </section>

    <div class="article-grid">
      <article class="article-main">
        {toc.length > 0 && (
          <nav class="toc" aria-label="Table of contents">
            <strong>Table of Contents</strong>
            {toc.map(item => <a class={`toc-${item.tag}`} href={`#${item.id}`}>{item.text}</a>)}
          </nav>
        )}

        <div class="article-content" set:html={html}></div>

        <div class="article-ad" aria-label="Advertisement">
          <ins
            class="adsbygoogle"
            style="display:block;text-align:center;"
            data-ad-layout="in-article"
            data-ad-format="fluid"
            data-ad-client="ca-pub-7728107798566122"
            data-ad-slot="5951785085"
          ></ins>
        </div>

        {related.length > 0 && (
          <section class="related">
            <h2>Related Posts</h2>
            <div class="card-grid">
              {related.map(item => <PostCard article={item} heading="h3" />)}
            </div>
          </section>
        )}
      </article>

      <aside class="article-side">
        <section class="side-panel">
          <h2>Tags</h2>
          <div class="tag-list">
            {(tags.length ? tags : ['travel']).map(tag => <span class="badge">{tag}</span>)}
          </div>
        </section>
        <section class="side-panel">
          <h2>Popular Posts</h2>
          <div class="side-posts">
            {popular.map(item => (
              <a href={articlePath(item)}>
                <img src={imageUrl(item.image)} alt={item.title || ''} loading="lazy" />
                <span>{item.title}</span>
              </a>
            ))}
          </div>
        </section>
      </aside>
    </div>
  </main>

  <script is:inline src="https://platform.twitter.com/widgets.js" async></script>
  <script>
    function safeViewerImageUrl(value) {
      if (!value) return null;
      try {
        const url = new URL(value, window.location.origin);
        const allowedLocalPath = url.origin === window.location.origin && url.pathname.startsWith('/contents/');
        const allowedMicrocmsCdn = url.hostname === 'images.microcms-assets.io' || url.hostname.endsWith('.microcms-assets.io');
        return allowedLocalPath || allowedMicrocmsCdn ? url.href : null;
      } catch {
        return null;
      }
    }

    document.querySelectorAll('.article-content img.cms-image').forEach(image => {
      image.addEventListener('click', () => {
        const src = safeViewerImageUrl(image.getAttribute('src'));
        if (!src) return;

        const overlay = document.createElement('button');
        const viewerImage = document.createElement('img');
        const closeViewer = () => {
          overlay.classList.remove('is-open');
          overlay.classList.add('is-closing');
          overlay.addEventListener('transitionend', () => overlay.remove(), { once: true });
        };

        overlay.className = 'image-viewer';
        overlay.type = 'button';
        viewerImage.setAttribute('src', src);
        viewerImage.setAttribute('alt', image.getAttribute('alt') || '');
        overlay.appendChild(viewerImage);
        overlay.addEventListener('click', closeViewer);
        document.body.appendChild(overlay);
        requestAnimationFrame(() => overlay.classList.add('is-open'));
      });
    });
  </script>
  <script is:inline>
    (window.adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</BaseLayout>

<style>
  .article-wrap {
    width: min(1200px, 92vw);
    margin: 24px auto 0;
  }

  .article-hero {
    position: relative;
    overflow: hidden;
    min-height: 420px;
    border-radius: 8px;
    background: #17331b;
  }

  .article-hero img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.72);
  }

  .article-hero__text {
    position: absolute;
    bottom: 44px;
    left: 44px;
    width: min(760px, calc(100% - 88px));
    padding: 28px 30px 26px;
    border-radius: 14px;
    background: rgba(14, 28, 21, 0.64);
    color: #fff;
    backdrop-filter: blur(6px);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.2);
  }

  .article-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .article-hero__pill {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    border-radius: 999px;
    background: rgba(47, 104, 75, 0.82);
    padding: 0 12px;
    color: #fff;
    font-size: 0.82rem;
    line-height: 1;
  }

  .article-hero h1 {
    margin: 0;
    font-size: clamp(2rem, 3.1vw, 2.7rem);
    line-height: 1.18;
  }

  .article-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 24px;
    align-items: start;
    margin-top: 24px;
  }

  .article-main,
  .side-panel {
    border: 1px solid var(--color-line);
    border-radius: 8px;
    background: #fff;
    box-shadow: var(--shadow-card);
  }

  .article-main {
    padding: clamp(18px, 3vw, 34px);
  }

  .toc {
    display: grid;
    gap: 6px;
    margin-bottom: 26px;
    border: 1px solid var(--color-line);
    border-radius: 8px;
    background: #f6fff6;
    padding: 14px;
  }

  .toc a {
    text-decoration: none;
  }

  .toc-h3 {
    padding-left: 14px;
    font-size: 0.94rem;
  }

  .article-content {
    font-size: 1.03rem;
  }

  .article-content :global(h2) {
    margin: 2.1em 0 0.9em;
    border-left: 7px solid var(--color-primary);
    border-radius: 0 8px 8px 0;
    background: #f6fff6;
    color: var(--color-primary);
    padding: 0.24em 0 0.24em 0.72em;
  }

  .article-content :global(h3) {
    margin: 1.7em 0 0.7em;
    border-left: 5px solid var(--color-secondary);
    border-radius: 0 8px 8px 0;
    background: #eaffea;
    color: var(--color-primary);
    padding: 0.2em 0 0.2em 0.62em;
  }

  .article-content :global(p) {
    max-width: 760px;
    margin: 0 auto 1.05em;
  }

  .article-content :global(.cms-image) {
    display: block;
    width: min(100%, 920px);
    margin: 22px auto;
    border-radius: 8px;
    cursor: zoom-in;
  }

  .article-side {
    position: sticky;
    top: 82px;
    display: grid;
    gap: 14px;
  }

  .side-panel {
    padding: 14px;
  }

  .side-panel h2 {
    margin: 0 0 10px;
    font-size: 1rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .side-posts {
    display: grid;
    gap: 10px;
  }

  .side-posts a {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 10px;
    align-items: center;
    color: inherit;
    text-decoration: none;
  }

  .side-posts img {
    width: 64px;
    height: 64px;
    border-radius: 8px;
    object-fit: cover;
  }

  .related {
    margin-top: 36px;
  }

  .article-ad {
    display: flex;
    justify-content: center;
    min-height: 180px;
    margin: 34px auto;
  }

  .article-ad .adsbygoogle {
    width: min(100%, 760px);
  }

  :global(.image-viewer) {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    width: 100%;
    min-height: 100dvh;
    border: 0;
    background: rgba(0, 0, 0, 0.82);
    padding: 16px;
    cursor: zoom-out;
    opacity: 0;
    overflow: hidden;
    transition: opacity 0.38s ease;
  }

  :global(.image-viewer.is-open) {
    opacity: 1;
  }

  :global(.image-viewer.is-closing) {
    opacity: 0;
  }

  :global(.image-viewer img) {
    display: block;
    width: auto;
    height: auto;
    max-width: min(1100px, calc(100vw - 32px));
    max-height: calc(100dvh - 32px);
    object-fit: contain;
    transform: scale(0.985);
    transition: transform 0.38s ease;
  }

  :global(.image-viewer.is-open img) {
    transform: scale(1);
  }

  @media (max-width: 900px) {
    .article-grid {
      grid-template-columns: 1fr;
    }

    .article-side {
      position: static;
    }

    .article-hero {
      min-height: 340px;
    }

    .article-hero__text {
      inset: auto 0 0;
      width: auto;
      padding: 24px;
      border-radius: 0;
      background: linear-gradient(180deg, rgba(9, 24, 11, 0), rgba(9, 24, 11, 0.82));
      transform: none;
      box-shadow: none;
      backdrop-filter: none;
    }

    .article-hero__meta {
      margin-top: 12px;
    }

    .article-hero h1 {
      font-size: 1rem;
    }

    .article-content :global(h2) {
      font-size: 1.25rem;
      line-height: 1.45;
    }

    .article-content :global(h3) {
      font-size: 1.1rem;
      line-height: 1.45;
    }

    .article-content :global(h4) {
      font-size: 1rem;
      line-height: 1.5;
    }
  }
</style>
