---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getArticles, getRecommendedArticles } from '../lib/microcms';
import { CATEGORIES, SITE_DESCRIPTION, SITE_NAME, articlePath, categoryKeyForArticle, categoryPath, excerptFromArticle, formatDate, imageUrl, stripHtml, tagLabels } from '../lib/site';

const articles = await getArticles();
const recommendedArticles = await getRecommendedArticles();
const latestArticle = articles[0] || recommendedArticles[0];
const latestTags = latestArticle ? tagLabels(latestArticle) : [];
const trendingArticles = (articles.length > 1 ? articles.slice(1) : recommendedArticles).slice(0, 3);
const heroImages = [...recommendedArticles, ...articles]
  .map(article => imageUrl(article.image))
  .filter(Boolean)
  .slice(0, 6);
const categoryDisplay = {
  domestic: { label: '国内旅行', icon: 'pin' },
  overseas: { label: '海外旅行', iconSrc: '/category-icons/flight.png' },
  lounge: { label: 'ラウンジ', iconSrc: '/category-icons/chair.png' },
  train: { label: '鉄道', iconSrc: '/category-icons/train.png' }
};
const searchArticles = articles.map(article => {
  const categoryKey = categoryKeyForArticle(article);
  const category = CATEGORIES.find(item => item.key === categoryKey);
  const title = article.title || 'Untitled';
  const excerpt = excerptFromArticle(article, '');
  const tags = tagLabels(article);
  const date = formatDate(article.publishedAt || article.createdAt || article.updatedAt);

  return {
    title,
    excerpt,
    tags,
    date,
    url: articlePath(article),
    image: imageUrl(article.image),
    category: category?.label || categoryKey || '',
    searchText: [
      title,
      excerpt,
      stripHtml(article.content || ''),
      tags.join(' '),
      category?.label || '',
      categoryKey || ''
    ].join(' ').toLowerCase()
  };
});
const searchArticlesJson = JSON.stringify(searchArticles).replace(/</g, '\\u003c');
---
<BaseLayout title={SITE_NAME} description={SITE_DESCRIPTION} canonical="/">
  <script is:inline>
    const params = new URLSearchParams(location.search);
    const p = params.get('p');
    const category = params.get('category');
    if (p) location.replace(`/articles/${encodeURIComponent(p)}/`);
    if (!p && category) location.replace(`/categories/${encodeURIComponent(category)}/`);
  </script>

  <header class="site-nav">
    <a class="brand" href="/">takatabi</a>
    <nav class="nav-links" aria-label="Main navigation">
      {CATEGORIES.map(category => <a href={categoryPath(category.key)}>{category.label}</a>)}
    </nav>
    <button class="subscribe" type="button">Subscribe</button>
  </header>

  <section class="hero" data-hero-images={JSON.stringify(heroImages)}>
    <div class="hero__bg" style={`background-image: linear-gradient(180deg, rgba(12, 34, 14, 0.36), rgba(12, 34, 14, 0.58)), url(${heroImages[0] || '/contents/photo/kyoto2.jpg'});`}></div>
    <div class="hero__content">
      <span class="hero__eyebrow">DISCOVER WORLD</span>
      <h1>Travel Within <span>Reach</span></h1>
      <p class="hero__lead hero__lead--typed" aria-label="コスパよくサステナブルな旅、ラウンジ情報や一人旅体験記。あなたの旅立ちをもっと身近に。">
        <span data-typewriter-line data-text="コスパよくサステナブルな旅、ラウンジ情報や一人旅体験記。">コスパよくサステナブルな旅、ラウンジ情報や一人旅体験記。</span><br />
        <span data-typewriter-line data-text="あなたの旅立ちをもっと身近に。">あなたの旅立ちをもっと身近に。</span><span class="typewriter-caret" aria-hidden="true"></span>
      </p>
      <a href="#articles" class="hero__button">Start Reading</a>
    </div>
  </section>

  <main class="page-wrap" id="articles">
    <section class="search-band">
      <label class="search-box">
        <span>Search</span>
        <input type="search" id="article-search" placeholder="keyword" />
      </label>
      <p class="meta" id="search-count"></p>
    </section>

    <section class="search-results" id="search-results" data-articles={searchArticlesJson} hidden>
      <div class="card-grid" id="search-results-grid"></div>
    </section>

    {recommendedArticles.length > 0 && (
      <section class="section section--framed">
        <div class="section__head">
          <div>
            <h2>Featured Stories</h2>
            <p>編集部おすすめの人気記事をピックアップ</p>
          </div>
          <a class="view-all" href={categoryPath('overseas')}>View All Posts <span aria-hidden="true">›</span></a>
        </div>
        <div class="card-grid card-grid--featured">
          {recommendedArticles.slice(0, 3).map(article => (
            <a class="post-card post-card--featured" href={articlePath(article)}>
              <img src={imageUrl(article.image)} alt={article.title || ''} loading="lazy" />
              <div class="post-card__body">
                <div class="post-card__tags" aria-label="Tags">
                  <span class="badge badge--recommend">★ おすすめ</span>
                  {tagLabels(article).map(tag => <span class="badge">{tag}</span>)}
                </div>
                <div class="meta">{formatDate(article.publishedAt || article.createdAt || article.updatedAt)}</div>
                <h3>{article.title || 'Untitled'}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {latestArticle && (
      <section class="latest-layout">
        <a class="latest-card" href={articlePath(latestArticle)}>
          <img src={imageUrl(latestArticle.image)} alt={latestArticle.title || ''} />
          <div class="latest-card__overlay">
            <div class="latest-card__rule"><span>{latestTags[0] || 'ROAD TRIP'}</span></div>
            <h2>{latestArticle.title}</h2>
            <p>新着記事のハイライトをご覧ください。</p>
            <strong>Read Article</strong>
          </div>
        </a>

        {trendingArticles.length > 0 && (
          <aside class="trending-panel">
            <h2><span aria-hidden="true">★</span> Trending Now</h2>
            <div class="trending-list">
              {trendingArticles.map(article => (
                <a class="trending-item" href={articlePath(article)}>
                  <img src={imageUrl(article.image)} alt={article.title || ''} loading="lazy" />
                  <div>
                    <p>{categoryDisplay[categoryKeyForArticle(article)]?.label || categoryKeyForArticle(article) || 'guide'}</p>
                    <h3>{article.title || 'Untitled'}</h3>
                  </div>
                </a>
              ))}
            </div>
          </aside>
        )}
      </section>
    )}

    {CATEGORIES.map(category => {
      const posts = articles.filter(article => categoryKeyForArticle(article) === category.key).slice(0, 3);
      const display = categoryDisplay[category.key] || { label: category.label, icon: 'pin' };
      const iconClass = display.iconSrc ? 'category-icon category-icon--image' : `category-icon category-icon--${display.icon}`;
      return (
        <section class="category-section">
          <div class="category-heading">
            <span class={iconClass} style={display.iconSrc ? `--icon-url: url('${display.iconSrc}')` : undefined} aria-hidden="true"></span>
            <h2>{display.label}</h2>
            <a class="view-all" href={categoryPath(category.key)}>さらに表示 <span aria-hidden="true">›</span></a>
          </div>
          {posts.length > 0 ? (
            <div class="card-grid" data-search-list>
              {posts.map(article => <PostCard article={article} heading="h3" showExcerpt={false} />)}
            </div>
          ) : (
            <p class="category-empty">このカテゴリの記事はまだありません。</p>
          )}
        </section>
      );
    })}
  </main>

  <script>
    const hero = document.querySelector('.hero');
    const heroBg = document.querySelector('.hero__bg');
    const images = JSON.parse(hero?.getAttribute('data-hero-images') || '[]');
    let index = 0;
    if (heroBg && images.length > 1) {
      window.setInterval(() => {
        index = (index + 1) % images.length;
        heroBg.style.backgroundImage = `linear-gradient(180deg, rgba(12, 34, 14, 0.36), rgba(12, 34, 14, 0.58)), url(${images[index]})`;
      }, 5000);
    }

    const search = document.getElementById('article-search');
    const count = document.getElementById('search-count');
    const results = document.getElementById('search-results');
    const resultsGrid = document.getElementById('search-results-grid');
    const defaultSections = Array.from(document.querySelectorAll('.section, .latest-layout, .category-section'));
    const articles = JSON.parse(results?.dataset.articles || '[]');
    const escapeHtml = value => String(value || '').replace(/[&<>"']/g, character => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;'
    })[character]);
    const renderArticle = article => `
      <a class="post-card" href="${escapeHtml(article.url)}">
        <img src="${escapeHtml(article.image)}" alt="${escapeHtml(article.title)}" loading="lazy" />
        <div class="post-card__body">
          ${article.tags.length ? `<div class="post-card__tags" aria-label="Tags">${article.tags.map(tag => `<span class="badge">${escapeHtml(tag)}</span>`).join('')}</div>` : ''}
          ${article.date ? `<div class="meta">${escapeHtml(article.date)}</div>` : ''}
          <h3>${escapeHtml(article.title)}</h3>
          ${article.excerpt ? `<p>${escapeHtml(article.excerpt)}</p>` : ''}
        </div>
      </a>
    `;
    search?.addEventListener('input', () => {
      const keyword = search.value.trim().toLowerCase();
      const matchedArticles = keyword
        ? articles.filter(article => article.searchText.includes(keyword))
        : [];

      defaultSections.forEach(section => {
        section.hidden = Boolean(keyword);
      });

      if (results && resultsGrid) {
        results.hidden = !keyword;
        resultsGrid.innerHTML = matchedArticles.map(renderArticle).join('');
      }
      if (count) count.textContent = keyword ? `${matchedArticles.length}件の記事が見つかりました` : '';
    });

    const typedLead = document.querySelector('.hero__lead--typed');
    const typedLines = Array.from(document.querySelectorAll('[data-typewriter-line]'));
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (typedLead && typedLines.length && !prefersReducedMotion) {
      typedLead.classList.add('is-typing');
      typedLines.forEach(line => { line.textContent = ''; });

      const wait = delay => new Promise(resolve => window.setTimeout(resolve, delay));

      const typeLine = async line => {
        const text = line.dataset.text || '';
        for (const char of text) {
          line.textContent += char;
          await wait(char === '、' || char === '。' ? 150 : 42);
        }
      };

      (async () => {
        for (const line of typedLines) {
          await typeLine(line);
          await wait(260);
        }
        typedLead.classList.remove('is-typing');
        typedLead.classList.add('is-typed');
      })();
    }
  </script>
</BaseLayout>

<style>
  .hero {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 520px;
    overflow: hidden;
    color: #fff;
    text-align: center;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-position: center;
    background-size: cover;
    transition: background-image 0.8s ease;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    width: min(760px, 92vw);
    padding: 48px 0;
  }

  .hero__eyebrow {
    display: inline-flex;
    border-radius: 999px;
    background: #43d35f;
    color: #09340f;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.32rem 0.72rem;
  }

  .hero h1 {
    margin: 14px 0 0;
    font-size: clamp(2.2rem, 6vw, 4.2rem);
    line-height: 1.02;
  }

  .hero h1 span {
    color: #48df69;
  }

  .hero p {
    margin: 18px auto 0;
    max-width: 620px;
    font-size: 1rem;
  }

  .hero__lead {
    min-height: 3.6em;
    line-height: 1.8;
  }

  .hero__lead--typed {
    text-wrap: balance;
  }

  .typewriter-caret {
    display: inline-block;
    width: 0.08em;
    height: 1.15em;
    margin-left: 0.12em;
    background: currentColor;
    vertical-align: -0.16em;
    animation: typewriter-caret 0.74s steps(1) infinite;
  }

  .hero__lead--typed.is-typed .typewriter-caret {
    animation-duration: 1.1s;
    opacity: 0.72;
  }

  @keyframes typewriter-caret {
    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .typewriter-caret {
      display: none;
    }
  }

  .hero__button {
    display: inline-flex;
    margin-top: 26px;
    border-radius: 8px;
    background: var(--color-primary);
    color: #fff;
    font-weight: 700;
    padding: 0.72rem 1.2rem;
    text-decoration: none;
  }

  .search-band,
  .section,
  .latest-layout,
  .category-section {
    margin-top: 34px;
  }

  .search-box {
    display: grid;
    gap: 8px;
  }

  .search-box input {
    width: 100%;
    border: 1px solid var(--color-line);
    border-radius: 8px;
    background: #fff;
    padding: 0.8rem 0.9rem;
    font-size: 1rem;
  }

  .section--framed {
    border: 1px solid var(--color-line);
    border-radius: 16px;
    background: rgba(247, 250, 247, 0.82);
    padding: 24px 22px 34px;
  }

  .section__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 28px;
  }

  .section__head h2 {
    margin: 0;
    color: #151515;
    font-size: clamp(1.85rem, 3vw, 2rem);
    line-height: 1.1;
  }

  .section__head p {
    margin: 6px 0 0;
    color: #5d6f5f;
    font-size: 0.92rem;
  }

  .view-all {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--color-primary);
    font-size: 0.86rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .card-grid--featured {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .post-card--featured img {
    height: 200px;
    aspect-ratio: auto;
  }

  .post-card--featured .post-card__body {
    padding: 20px 16px 22px;
  }

  .badge--recommend {
    background: #ffe83a;
    color: #5f5700;
  }

  .latest-layout {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 18px;
    align-items: stretch;
  }

  .latest-card {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: 340px;
    border-radius: 14px;
    background: #16351a;
    color: #fff;
    text-decoration: none;
  }

  .latest-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .latest-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 24px 18px 20px;
    background: linear-gradient(180deg, rgba(8, 20, 8, 0.05), rgba(8, 20, 8, 0.72));
  }

  .latest-card__rule {
    display: flex;
    align-items: center;
    width: 100%;
    height: 20px;
    margin-bottom: 10px;
    border-radius: 999px;
    background: #39df59;
  }

  .latest-card__rule span {
    padding: 0 10px;
    color: #062d0b;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .latest-card h2 {
    margin: 0;
    max-width: 680px;
    color: #fff;
    font-size: clamp(1.45rem, 2.5vw, 2rem);
    line-height: 1.24;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.28);
  }

  .latest-card p {
    margin: 10px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.95rem;
  }

  .latest-card strong {
    display: inline-flex;
    width: fit-content;
    margin-top: 14px;
    border-radius: 999px;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.88rem;
    padding: 0.5rem 0.95rem;
  }

  .trending-panel {
    border: 1px solid var(--color-line);
    border-radius: 14px;
    background: rgba(247, 250, 247, 0.9);
    padding: 16px;
  }

  .trending-panel h2 {
    margin: 0;
    color: #151515;
    font-size: 1.18rem;
    line-height: 1.2;
  }

  .trending-list {
    display: grid;
    gap: 12px;
    margin-top: 16px;
  }

  .trending-item {
    display: grid;
    grid-template-columns: 66px minmax(0, 1fr);
    gap: 10px;
    align-items: start;
    color: inherit;
    text-decoration: none;
  }

  .trending-item img {
    width: 66px;
    height: 66px;
    border-radius: 8px;
    object-fit: cover;
  }

  .trending-item p {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .trending-item h3 {
    margin: 2px 0 0;
    color: #1d1d1d;
    font-size: 0.9rem;
    line-height: 1.38;
  }

  .category-section {
    margin-bottom: 32px;
  }

  .category-heading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin-bottom: 30px;
  }

  .category-heading h2 {
    margin: 0;
    color: var(--color-primary);
    font-size: 1.45rem;
    line-height: 1.2;
  }

  .category-empty {
    margin: 0;
    border: 1px solid var(--color-line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-muted);
    padding: 18px;
    text-align: center;
  }

  .category-icon {
    position: relative;
    display: block;
    width: 28px;
    height: 40px;
  }

  .category-icon--image {
    width: 40px;
    height: 40px;
    background: var(--color-primary);
    mask: var(--icon-url) center / 32px 32px no-repeat;
    -webkit-mask: var(--icon-url) center / 32px 32px no-repeat;
  }

  .category-icon--pin::before {
    content: '';
    position: absolute;
    top: 1px;
    left: 0;
    width: 28px;
    height: 28px;
    background: var(--color-primary);
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
  }

  .category-icon--pin::after {
    content: '';
    position: absolute;
    top: 9px;
    left: 9px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #f4faf3;
  }

  @media (max-width: 760px) {
    .hero {
      min-height: 460px;
    }

    .section__head {
      align-items: flex-start;
      flex-direction: column;
    }

    .card-grid--featured,
    .latest-layout {
      grid-template-columns: 1fr;
    }

    .latest-card {
      min-height: 360px;
    }
  }
</style>
