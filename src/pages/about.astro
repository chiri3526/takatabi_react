---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORIES, categoryPath } from '../lib/site';

const profileImage = '/contents/photo/kyoto2.jpg';
const pageDescription = 'takatabiを運営するたかたびのプロフィール。日本全国47都道府県を訪問・宿泊した経験をもとに、鉄道旅や快適な旅のヒントを発信しています。';

const themes = [
  {
    title: '鉄道で行く国内旅',
    text: '駅から始まる旅の楽しさや、移動時間も含めて味わえる国内旅を紹介します。'
  },
  {
    title: '知らない街での小さな発見',
    text: '有名な観光地だけでなく、街歩きの途中で出会う景色や空気も大切にしています。'
  },
  {
    title: '移動や宿泊を快適にする工夫',
    text: '実際に歩き、乗り、泊まって感じたことをもとに、旅を少し快適にするヒントを残します。'
  }
];
---

<BaseLayout title="About Me" description={pageDescription} canonical="/about/">
  <header class="site-nav">
    <a class="brand" href="/">takatabi</a>
    <nav class="nav-links" aria-label="Main navigation">
      {CATEGORIES.map(category => <a href={categoryPath(category.key)}>{category.label}</a>)}
    </nav>
    <button class="subscribe" type="button">Subscribe</button>
  </header>

  <main class="page-wrap about-page">
    <section class="about-hero">
      <div class="about-hero__content">
        <p class="about-hero__eyebrow">About Me</p>
        <h1>たかたび</h1>
        <p class="about-hero__role">旅と移動の案内人</p>
        <p class="about-hero__lead">
          次の旅先を探している方へ、実体験をもとにした旅のヒントをお届けしています。
        </p>
      </div>
      <figure class="about-hero__image">
        <img src={profileImage} alt="たかたびのプロフィール仮画像" />
      </figure>
    </section>

    <section class="about-body" aria-labelledby="about-profile-title">
      <h2 id="about-profile-title">はじめまして</h2>
      <div class="about-body__text">
        <p>はじめまして。takatabiを運営している、たかたびです。</p>
        <p>旅先で出会う小さな発見と、そこへ向かうまでの移動時間が好きで、国内を中心にさまざまな場所を訪ねています。これまでに日本全国47都道府県を訪問し、すべての都道府県で宿泊してきました。</p>
        <p>このブログでは、実際に自分で歩き、乗り、泊まって感じたことをもとに、次の旅先を探している方に役立つ情報をお届けしています。特に、鉄道で行く旅や、現地での過ごし方、移動を少し快適にする工夫を大切にしています。</p>
        <p>旅は、有名な観光地を巡るだけでなく、知らない街を歩いたときの空気や、駅前で見つけた景色、予定外に出会った場所にも魅力があると思っています。だからこそ、記事では実体験をもとに、旅の楽しさとあわせて「どう行くか」「どう過ごすと快適か」も丁寧に残していきます。</p>
        <p>takatabiが、あなたの次の旅先を見つけるきっかけになればうれしいです。</p>
      </div>
    </section>

    <section class="about-themes" aria-labelledby="about-themes-title">
      <div class="section-head">
        <p class="meta">Topics</p>
        <h2 id="about-themes-title">takatabiで発信していること</h2>
      </div>
      <div class="theme-grid">
        {themes.map(theme => (
          <article class="theme-card">
            <h3>{theme.title}</h3>
            <p>{theme.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="about-cta" aria-labelledby="about-cta-title">
      <p class="meta">Start Reading</p>
      <h2 id="about-cta-title">次の旅先を探しにいく</h2>
      <p>国内旅や移動のヒントを、記事の中で少しずつ紹介しています。</p>
      <a href="/" class="about-cta__button">旅の記事を見る</a>
    </section>
  </main>
</BaseLayout>

<style>
  .about-page {
    padding-top: 38px;
  }

  .about-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: 28px;
    align-items: center;
    border: 1px solid var(--color-line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: var(--shadow-card);
    padding: clamp(24px, 5vw, 46px);
  }

  .about-hero__eyebrow,
  .about-hero__role {
    margin: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .about-hero__eyebrow {
    font-size: 0.82rem;
    text-transform: uppercase;
  }

  .about-hero h1 {
    margin: 10px 0 0;
    color: #151515;
    font-size: clamp(2.3rem, 6vw, 4rem);
    line-height: 1.08;
  }

  .about-hero__role {
    margin-top: 8px;
    font-size: 1.08rem;
  }

  .about-hero__lead {
    max-width: 560px;
    margin: 22px 0 0;
    color: var(--color-muted);
    font-size: 1rem;
  }

  .about-hero__image {
    margin: 0;
  }

  .about-hero__image img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 8px;
    object-fit: cover;
    background: #e7efe7;
  }

  .about-body,
  .about-themes,
  .about-cta {
    margin-top: 34px;
  }

  .about-body {
    display: grid;
    grid-template-columns: minmax(180px, 260px) minmax(0, 1fr);
    gap: 28px;
    align-items: start;
  }

  .about-body h2,
  .section-head h2,
  .about-cta h2 {
    margin: 0;
    color: #151515;
    font-size: clamp(1.6rem, 3vw, 2rem);
    line-height: 1.25;
  }

  .about-body__text {
    border-left: 3px solid var(--color-primary);
    padding-left: 22px;
  }

  .about-body__text p {
    margin: 0;
    color: var(--color-text);
    font-size: 1rem;
  }

  .about-body__text p + p {
    margin-top: 1.1rem;
  }

  .section-head {
    margin-bottom: 18px;
    text-align: center;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .theme-card {
    border: 1px solid var(--color-line);
    border-radius: 8px;
    background: #fff;
    box-shadow: var(--shadow-card);
    padding: 20px;
  }

  .theme-card h3 {
    margin: 0;
    color: var(--color-primary);
    font-size: 1.05rem;
    line-height: 1.4;
  }

  .theme-card p {
    margin: 10px 0 0;
    color: var(--color-muted);
    font-size: 0.92rem;
  }

  .about-cta {
    border: 1px solid var(--color-line);
    border-radius: 8px;
    background: rgba(247, 250, 247, 0.9);
    padding: 28px;
    text-align: center;
  }

  .about-cta p {
    margin: 10px auto 0;
    max-width: 560px;
    color: var(--color-muted);
  }

  .about-cta__button {
    display: inline-flex;
    margin-top: 22px;
    border-radius: 8px;
    background: var(--color-primary);
    color: #fff;
    font-weight: 700;
    padding: 0.72rem 1.2rem;
    text-decoration: none;
  }

  @media (max-width: 780px) {
    .about-page {
      padding-top: 28px;
    }

    .about-hero,
    .about-body,
    .theme-grid {
      grid-template-columns: 1fr;
    }

    .about-hero__image {
      order: -1;
    }

    .about-hero__image img {
      aspect-ratio: 16 / 10;
    }

    .about-body__text {
      border-left: 0;
      border-top: 3px solid var(--color-primary);
      padding: 18px 0 0;
    }
  }
</style>
