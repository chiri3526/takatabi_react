---
import type { Article } from '../lib/microcms';
import { articlePath, excerptFromArticle, formatDate, imageUrl, tagLabels } from '../lib/site';

type Props = {
  article: Article;
  heading?: 'h2' | 'h3';
  showExcerpt?: boolean;
};

const { article, heading = 'h2', showExcerpt = true } = Astro.props;
const Heading = heading;
const date = formatDate(article.publishedAt || article.createdAt || article.updatedAt);
const tags = tagLabels(article);
---
<a class="post-card" href={articlePath(article)}>
  <img src={imageUrl(article.image)} alt={article.title || ''} loading="lazy" />
  <div class="post-card__body">
    {tags.length > 0 && (
      <div class="post-card__tags" aria-label="Tags">
        {tags.map(tag => <span class="badge">{tag}</span>)}
      </div>
    )}
    {date && <div class="meta">{date}</div>}
    <Heading>{article.title || 'Untitled'}</Heading>
    {showExcerpt && <p>{excerptFromArticle(article)}</p>}
  </div>
</a>
